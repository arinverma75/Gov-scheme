{
  "version": 2,
  "buildCommand": "npm run build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/serverless.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/serverless.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
