{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install --no-package-lock",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/serverless.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/serverless.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "backend/data/**"
    }
  }
}
